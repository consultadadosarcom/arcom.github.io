rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ====== AUTENTICAÇÃO ======
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isManager() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['admin', 'manager'];
    }
    
    function mesmaEquipe(userId) {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.equipe_id == 
             get(/databases/$(database)/documents/usuarios/$(userId)).data.equipe_id;
    }
    
    // ====== USUARIOS ======
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (uid == request.auth.uid || isManager());
      allow create: if isSignedIn() && uid == request.auth.uid;
      allow update: if isSignedIn() && (uid == request.auth.uid || isAdmin());
      allow delete: if false;
    }
    
    // ====== EQUIPES ======
    match /equipes/{equipeId} {
      allow read: if isSignedIn() && 
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.equipe_id == equipeId);
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }
    
    // ====== CONSULTAS ======
    match /consultas/{consultaId} {
      allow read: if isSignedIn() && 
        (resource.data.usuario_id == request.auth.uid || 
         mesmaEquipe(resource.data.usuario_id));
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.usuario_id == request.auth.uid;
    }
    
    // ====== AUDITORIA ======
    match /auditoria/{logId} {
      allow read: if isSignedIn() && isManager();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // ====== EMPRESAS MONITORADAS ======
    match /empresas_monitoradas/{id} {
      allow read: if isSignedIn() && 
        (resource.data.usuario_id == request.auth.uid || 
         mesmaEquipe(resource.data.usuario_id));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.usuario_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.usuario_id == request.auth.uid;
    }
    
    // ====== ALERTAS ======
    match /alertas/{alertaId} {
      allow read: if isSignedIn() && resource.data.usuario_id == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn() && resource.data.usuario_id == request.auth.uid;
    }
  }
}
